# Reference snippets for non-default probe-rs or toolchain layouts.
# `.cargo/config.toml` already covers the standard setup — copy from here only
# if you need to override.

[target.'cfg(all(target_arch = "arm", target_os = "none"))']
runner = "probe-rs run --chip STM32U5A9NJHxQ --preverify"

[build]
target = "thumbv8m.main-none-eabihf"

[target.thumbv8m.main-none-eabihf]
linker = "rust-lld"

[env]
DEFMT_LOG = "info"
