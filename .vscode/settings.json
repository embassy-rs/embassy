{
  "[toml]": {
    "editor.formatOnSave": false
  },
  "[markdown]": {
    "editor.formatOnSave": false
  },
  "rust-analyzer.rustfmt.extraArgs": [
    "+nightly"
  ],
  "rust-analyzer.check.allTargets": false,
  "rust-analyzer.check.noDefaultFeatures": true,
  "rust-analyzer.cargo.noDefaultFeatures": true,
  "rust-analyzer.showUnlinkedFileNotification": false,

  // RVT50 (STM32U5A9NJH6Q, thumbv8m.main-none-eabihf)
  // The example crate uses nightly (see examples/rvt50hqsnwc00-b/rust-toolchain.toml).
  // Force the same toolchain here so proc-macro ABI matches the root rust-toolchain.toml (1.92 stable).
  "rust-analyzer.server.extraEnv": {
    "RUSTUP_TOOLCHAIN": "nightly-2025-12-11"
  },
  "rust-analyzer.cargo.extraEnv": {
    "RUSTUP_TOOLCHAIN": "nightly-2025-12-11"
  },
  "rust-analyzer.cargo.target": "thumbv8m.main-none-eabihf",
  // Uncomment for oxivgl_widget_demo analysis:
  "rust-analyzer.cargo.features": ["oxivgl"],

  // To work on embassy-stm32 instead, comment the line below and restore
  // embassy-stm32/Cargo.toml plus the stm32f107 features block.
  "rust-analyzer.linkedProjects": [
    "examples/rvt50hqsnwc00-b/Cargo.toml"
  ],

  // --- embassy-stm32 development (comment out when using RVT50 above) ---
  //"rust-analyzer.cargo.target": "thumbv7em-none-eabi",
  //"rust-analyzer.cargo.features": [
  //  "stm32f107rb",
  //  "time-driver-any",
  //  "unstable-pac",
  //  "exti",
  //  "rt",
  //],
  //"rust-analyzer.linkedProjects": [
  //  "embassy-stm32/Cargo.toml",
  //],
}
